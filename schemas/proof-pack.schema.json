{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LalaSkye/artifact-readiness-engine/schemas/proof-pack.schema.json",
  "title": "Proof Pack",
  "description": "Canonical v0.1 proof-pack format for inspecting whether an artefact can support a bounded governance or AI-control claim.",
  "type": "object",
  "required": [
    "claim_id",
    "claim_type",
    "claim",
    "object",
    "authority",
    "conditions",
    "evidence",
    "receipt",
    "replay",
    "downstream_effect"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "minLength": 1
    },
    "claim_type": {
      "type": "string",
      "enum": ["allow", "refusal", "interruption", "audit", "documentation", "observation", "other"]
    },
    "claim": {
      "type": "object",
      "required": ["text", "limits"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "limits": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "object": {
      "type": "object",
      "required": ["id", "description"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["type", "reference"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["human", "role", "policy", "system", "hybrid", "unknown"]
        },
        "reference": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "result"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": ["confirmed", "pass", "fail", "unknown"]
          }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "reference", "supports_claim"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["log", "receipt", "screenshot", "policy", "test", "hash", "audit_note", "policy_evaluation_trace", "decision_log", "evaluation_trace", "other"]
          },
          "reference": {
            "type": "string",
            "minLength": 1
          },
          "supports_claim": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "receipt": {
      "type": ["object", "null"],
      "properties": {
        "present": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": ["none", "manual", "system_log", "signed", "hash_chain", "external_audit", "refusal_receipt", "allow_receipt", "interruption_receipt"]
        },
        "reference": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": ["present", "type", "reference", "timestamp"],
      "additionalProperties": false
    },
    "replay": {
      "type": ["object", "null"],
      "properties": {
        "present": {
          "type": "boolean"
        },
        "fixture": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": ["present"],
      "additionalProperties": false
    },
    "downstream_effect": {
      "type": ["object", "null"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["blocked", "allowed", "unknown", "not_applicable"]
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["status"],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
