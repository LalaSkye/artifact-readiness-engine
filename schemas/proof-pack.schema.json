{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LalaSkye/artifact-readiness-engine/schemas/proof-pack.schema.json",
  "title": "Proof Pack",
  "description": "Minimal structure for inspecting whether an artefact can support a bounded governance or AI-control claim.",
  "type": "object",
  "required": [
    "claim",
    "object",
    "authority",
    "conditions",
    "evidence",
    "receipt",
    "limits"
  ],
  "properties": {
    "claim": {
      "type": "object",
      "required": ["statement", "claim_type"],
      "properties": {
        "statement": { "type": "string", "minLength": 1 },
        "claim_type": {
          "type": "string",
          "enum": ["allow", "refusal", "interruption", "audit", "documentation", "other"]
        },
        "scope": { "type": "string" }
      },
      "additionalProperties": false
    },
    "object": {
      "type": "object",
      "required": ["object_type", "identifier"],
      "properties": {
        "object_type": {
          "type": "string",
          "enum": ["request", "decision", "transition", "refusal", "receipt", "audit_event", "execution_attempt", "other"]
        },
        "identifier": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["authority_type", "authority_reference"],
      "properties": {
        "authority_type": {
          "type": "string",
          "enum": ["human", "role", "policy", "system", "hybrid", "unknown"]
        },
        "authority_reference": { "type": "string", "minLength": 1 },
        "approval_basis": { "type": "string" }
      },
      "additionalProperties": false
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition", "result"],
        "properties": {
          "condition": { "type": "string", "minLength": 1 },
          "result": { "type": "string", "enum": ["pass", "fail", "unknown"] },
          "evidence_reference": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_type", "reference"],
        "properties": {
          "evidence_type": {
            "type": "string",
            "enum": ["log", "receipt", "screenshot", "policy", "test", "hash", "audit_note", "other"]
          },
          "reference": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "receipt": {
      "type": "object",
      "required": ["present", "receipt_type"],
      "properties": {
        "present": { "type": "boolean" },
        "receipt_type": {
          "type": "string",
          "enum": ["none", "manual", "system_log", "signed", "hash_chain", "external_audit"]
        },
        "timestamp": { "type": "string" },
        "reference": { "type": "string" },
        "downstream_effect_status": {
          "type": "string",
          "enum": ["blocked", "allowed", "unknown", "not_applicable"]
        }
      },
      "additionalProperties": false
    },
    "replay": {
      "type": "object",
      "properties": {
        "replayable": { "type": "boolean" },
        "replay_reference": { "type": "string" },
        "known_missing_inputs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
