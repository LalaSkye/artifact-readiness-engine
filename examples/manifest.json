      "expected_status": "HOLD",
      "tags": ["refusal", "missing-receipt", "missing-replay", "downstream-unknown"]
    },
    {
      "id": "fail-overbroad-claim",
      "path": "examples/fail/overbroad-claim.json",
      "report_path": "examples/reports/fail-overbroad-claim.report.json",
      "expected_status": "FAIL",
      "tags": ["documentation", "overbroad-claim", "missing-evidence", "unknown-authority"]
    }
  ]
