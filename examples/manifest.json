{
  "version": "0.1",
  "description": "Canonical proof-pack examples used for validation, inspection, golden report generation, and regression testing.",
  "examples": [
    {
      "id": "pass-minimal-refusal-receipt",
      "path": "examples/pass/minimal-refusal-receipt.json",
